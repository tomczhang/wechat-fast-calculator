.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* ========== 加载 & 错误 ========== */

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 400rpx;
}

.spinner {
  width: 56rpx;
  height: 56rpx;
  border: 5rpx solid #E5E5EA;
  border-top-color: #000000;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  color: #8E8E93;
  font-size: 26rpx;
}

.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 320rpx;
}

.error-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}

.error-text {
  color: #FF3B30;
  font-size: 28rpx;
  text-align: center;
  margin-bottom: 40rpx;
  padding: 0 48rpx;
}

/* ========== Hero 主区域 ========== */

.hero {
  padding: 20rpx 48rpx 48rpx;
  background-color: #FFFFFF;
}

.hero-label {
  display: block;
  font-size: 22rpx;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #8E8E93;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.hero-number {
  display: flex;
  align-items: baseline;
}

.hero-sign {
  font-size: 100rpx;
  font-weight: 900;
  line-height: 0.85;
  letter-spacing: -0.05em;
  margin-right: -6rpx;
}

.hero-integer {
  font-size: 180rpx;
  font-weight: 900;
  line-height: 0.85;
  letter-spacing: -0.06em;
}

.hero-decimal {
  font-size: 80rpx;
  font-weight: 800;
  letter-spacing: -0.04em;
  margin-left: 4rpx;
}

/* 跌幅颜色 */
.color-red { color: #FF3333; }
.color-orange { color: #FF9500; }
.color-green { color: #34C759; }

.dd-red { background: rgba(255, 51, 51, 0.08); color: #FF3333; }
.dd-orange { background: rgba(255, 149, 0, 0.08); color: #FF9500; }
.dd-green { background: rgba(52, 199, 89, 0.08); color: #34C759; }

/* ========== 标尺 ========== */

.ruler-container {
  margin-top: 48rpx;
  margin-bottom: 40rpx;
  position: relative;
  height: 64rpx;
  width: 100%;
}

.ruler {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: repeating-linear-gradient(to right, #E5E5EA 0, #E5E5EA 2rpx, transparent 2rpx, transparent 8rpx);
  -webkit-mask-image: linear-gradient(to right, rgba(0,0,0,0.1), black 20%, black 80%, rgba(0,0,0,0.1));
  mask-image: linear-gradient(to right, rgba(0,0,0,0.1), black 20%, black 80%, rgba(0,0,0,0.1));
}

.ruler-needle {
  position: absolute;
  top: -8rpx;
  width: 4rpx;
  height: 80rpx;
  background-color: #FF3333;
  z-index: 2;
  transition: left 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

.ruler-needle-dot {
  position: absolute;
  top: -6rpx;
  left: -5rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background-color: #FF3333;
}

/* ========== Hero Meta ========== */

.hero-meta {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding-top: 24rpx;
  border-top: 1rpx solid #E5E5EA;
}

.meta-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.meta-label {
  font-size: 20rpx;
  color: #8E8E93;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-weight: 500;
}

.meta-values {
  display: flex;
  align-items: baseline;
}

.meta-value {
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: -0.02em;
}

.meta-arrow {
  font-size: 28rpx;
  font-weight: 400;
  color: #8E8E93;
  margin: 0 8rpx;
}

.allocation-badge {
  display: flex;
  align-items: center;
  background: #F0F0F0;
  padding: 10rpx 20rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: -0.01em;
  gap: 12rpx;
  flex-shrink: 0;
}

.badge-dot {
  width: 6rpx;
  height: 6rpx;
  background: #8E8E93;
  border-radius: 50%;
}

/* ========== 卡片区域 ========== */

.details-section {
  background-color: #F4F5F7;
  flex-grow: 1;
  padding: 36rpx 36rpx 0;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  border-radius: 48rpx 48rpx 0 0;
  box-shadow: 0 -10rpx 40rpx rgba(0,0,0,0.03);
  position: relative;
  z-index: 2;
}

.etf-card {
  background: #FFFFFF;
  border-radius: 36rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  border: 1rpx solid rgba(0,0,0,0.04);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.ticker-group {
  display: flex;
  flex-direction: column;
}

.ticker {
  font-size: 48rpx;
  font-weight: 900;
  letter-spacing: -0.04em;
  line-height: 1;
}

.etf-name {
  font-size: 22rpx;
  color: #8E8E93;
  margin-top: 10rpx;
  font-weight: 500;
  max-width: 320rpx;
  line-height: 1.3;
}

.card-drawdown {
  font-size: 36rpx;
  font-weight: 800;
  letter-spacing: -0.03em;
  padding: 8rpx 18rpx;
  border-radius: 14rpx;
}

.card-data-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #E5E5EA;
}

.data-point {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.data-point-full {
  grid-column: 1 / -1;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: baseline;
  padding-top: 20rpx;
  border-top: 1rpx dashed #E5E5EA;
}

.dp-label {
  font-size: 20rpx;
  color: #8E8E93;
  text-transform: uppercase;
  font-weight: 600;
}

.dp-value {
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: -0.01em;
}

.dp-value-large {
  font-size: 36rpx;
  font-weight: 800;
  letter-spacing: -0.01em;
}

/* ========== Footer ========== */

.footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 12rpx 56rpx;
}

.update-time {
  font-size: 22rpx;
  color: #8E8E93;
  font-weight: 500;
  letter-spacing: 0.02em;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.update-dot {
  width: 10rpx;
  height: 10rpx;
  background-color: #34C759;
  border-radius: 50%;
}

.btn-refresh {
  background: #000000;
  color: #FFFFFF;
  padding: 20rpx 40rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 0.02em;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
