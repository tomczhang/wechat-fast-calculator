<view class="container">
  <!-- 标题 -->
  <view class="header">
    <text class="header-title">七姐妹 + 台积电</text>
    <text class="header-sub">Magnificent 7 & TSM Drawdown</text>
  </view>

  <!-- 加载进度 -->
  <view class="loading-bar" wx:if="{{loading}}">
    <view class="spinner-sm"></view>
    <text class="loading-text">{{progress ? '加载中 ' + progress : '获取数据...'}}</text>
  </view>

  <!-- 错误 -->
  <view class="error-wrap" wx:if="{{error && !cards.length}}">
    <text class="error-text">{{error}}</text>
    <view class="btn-refresh" bindtap="onRefresh">重试</view>
  </view>

  <!-- 卡片区域 -->
  <view class="cards-section" wx:if="{{cards.length}}">
    <view class="etf-card" wx:for="{{cards}}" wx:key="ticker">
      <view class="card-header">
        <view class="ticker-group">
          <text class="ticker">{{item.ticker}}</text>
          <text class="etf-name">{{item.nameEN}}</text>
        </view>
        <view class="card-drawdown {{item.dropClass}}">
          <text>{{item.dropFromHigh}}%</text>
        </view>
      </view>
      <view class="card-data-grid">
        <view class="data-point">
          <text class="dp-label">6月最高 Peak</text>
          <text class="dp-value">${{item.highPrice}}</text>
        </view>
        <view class="data-point">
          <text class="dp-label">最高日期 Date</text>
          <text class="dp-value">{{item.highDate}}</text>
        </view>
        <view class="data-point-full">
          <text class="dp-label">当前价格 Current</text>
          <text class="dp-value-large">${{item.currentPrice}}</text>
        </view>
      </view>
    </view>

    <!-- 底部 -->
    <view class="footer">
      <view class="update-time" wx:if="{{updateTime}}">
        <view class="update-dot"></view>
        <text>{{updateTime}} 更新</text>
      </view>
      <view class="btn-refresh" bindtap="onRefresh">
        <text wx:if="{{loading}}">刷新中...</text>
        <text wx:else>刷新数据</text>
      </view>
    </view>
  </view>
</view>
