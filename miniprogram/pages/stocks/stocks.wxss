.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #FFFFFF;
}

/* ========== Header ========== */

.header {
  padding: 24rpx 48rpx 16rpx;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: -0.04em;
  line-height: 1.1;
}

.header-sub {
  display: block;
  font-size: 20rpx;
  color: #8E8E93;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  font-weight: 500;
  margin-top: 6rpx;
}

/* ========== Loading ========== */

.loading-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 48rpx;
  background: #F9F9FB;
}

.spinner-sm {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid #E5E5EA;
  border-top-color: #000;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: #8E8E93;
  font-weight: 500;
}

/* ========== Error ========== */

.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.error-text {
  color: #FF3B30;
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

/* ========== Cards ========== */

.cards-section {
  flex-grow: 1;
  background: #F4F5F7;
  border-radius: 48rpx 48rpx 0 0;
  padding: 28rpx 28rpx 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  box-shadow: 0 -10rpx 40rpx rgba(0,0,0,0.03);
}

.etf-card {
  background: #FFFFFF;
  border-radius: 36rpx;
  padding: 28rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  border: 1rpx solid rgba(0,0,0,0.04);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.ticker-group {
  display: flex;
  flex-direction: column;
}

.ticker {
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: -0.04em;
  line-height: 1;
}

.etf-name {
  font-size: 20rpx;
  color: #8E8E93;
  margin-top: 8rpx;
  font-weight: 500;
  max-width: 320rpx;
  line-height: 1.3;
}

.card-drawdown {
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: -0.03em;
  padding: 8rpx 16rpx;
  border-radius: 14rpx;
}

.dd-red { background: rgba(255, 51, 51, 0.08); color: #FF3333; }
.dd-orange { background: rgba(255, 149, 0, 0.08); color: #FF9500; }
.dd-green { background: rgba(52, 199, 89, 0.08); color: #34C759; }

.card-data-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #E5E5EA;
}

.data-point {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.data-point-full {
  grid-column: 1 / -1;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: baseline;
  padding-top: 16rpx;
  border-top: 1rpx dashed #E5E5EA;
}

.dp-label {
  font-size: 20rpx;
  color: #8E8E93;
  text-transform: uppercase;
  font-weight: 600;
}

.dp-value {
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: -0.01em;
}

.dp-value-large {
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: -0.01em;
}

/* ========== Footer ========== */

.footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 12rpx 56rpx;
}

.update-time {
  font-size: 22rpx;
  color: #8E8E93;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.update-dot {
  width: 10rpx;
  height: 10rpx;
  background-color: #34C759;
  border-radius: 50%;
}

.btn-refresh {
  background: #000000;
  color: #FFFFFF;
  padding: 16rpx 32rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 700;
}
