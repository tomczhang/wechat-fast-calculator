.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #F4F5F7;
}

/* ========== Header ========== */
.header {
  padding: 24rpx 40rpx 16rpx;
  background: #FFFFFF;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 900;
  letter-spacing: -0.04em;
  line-height: 1.1;
}

.header-sub {
  display: block;
  font-size: 22rpx;
  color: #8E8E93;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-weight: 500;
  margin-top: 6rpx;
}

/* ========== Loading ========== */
.loading-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 40rpx;
  background: #FFFFFF;
}

.spinner-sm {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid #E5E5EA;
  border-top-color: #000;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: #8E8E93;
  font-weight: 500;
}

/* ========== Error ========== */
.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.error-text {
  color: #FF3B30;
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

/* ========== Section ========== */
.section {
  padding: 24rpx 28rpx 0;
}

.section-label {
  font-size: 24rpx;
  color: #8E8E93;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

/* ========== 宽指卡片 ========== */
.index-cards {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.index-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.06);
}

.index-card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.index-card-left {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.index-ticker {
  font-size: 36rpx;
  font-weight: 900;
  letter-spacing: -0.03em;
}

.index-name {
  font-size: 24rpx;
  color: #8E8E93;
  font-weight: 500;
}

.index-drop {
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 900;
  letter-spacing: -0.02em;
}

.index-card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.index-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

/* ========== 击球点 ========== */
.strike-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  background: rgba(255, 59, 48, 0.1);
  color: #FF3B30;
}

.strike-icon {
  font-size: 24rpx;
}

.strike-inactive {
  background: rgba(142, 142, 147, 0.08);
  color: #8E8E93;
  font-weight: 500;
}

.strike-dot {
  font-size: 28rpx;
  color: #FF3B30;
}

/* ========== VIX 卡片 ========== */
.vix-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 2rpx solid rgba(0, 0, 0, 0.06);
}

.vix-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.vix-value {
  font-size: 48rpx;
  font-weight: 900;
  letter-spacing: -0.03em;
}

.vix-change {
  font-size: 24rpx;
  font-weight: 600;
}

.vix-up {
  color: #FF3B30;
}

.vix-down {
  color: #34C759;
}

/* ========== 恐慌等级 ========== */
.panic-badge {
  padding: 10rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.panic-normal {
  background: rgba(52, 199, 89, 0.1);
  color: #34C759;
}

.panic-elevated {
  background: rgba(255, 149, 0, 0.1);
  color: #FF9500;
}

.panic-high {
  background: rgba(255, 59, 48, 0.1);
  color: #FF3B30;
}

.panic-extreme {
  background: rgba(175, 0, 0, 0.15);
  color: #AF0000;
}

/* ========== 个股列表 ========== */
.stock-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.stock-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.stock-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.stock-rank {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  background: #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
  color: #8E8E93;
}

.stock-info {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.stock-ticker {
  font-size: 28rpx;
  font-weight: 800;
  letter-spacing: -0.02em;
}

.stock-name {
  font-size: 20rpx;
  color: #8E8E93;
  font-weight: 500;
}

.stock-right {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.stock-price {
  font-size: 24rpx;
  color: #8E8E93;
  font-weight: 500;
}

.stock-badge {
  padding: 8rpx 16rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: -0.02em;
  min-width: 110rpx;
  text-align: center;
}

.dd-red { background: rgba(255, 51, 51, 0.08); color: #FF3333; }
.dd-orange { background: rgba(255, 149, 0, 0.08); color: #FF9500; }
.dd-green { background: rgba(52, 199, 89, 0.08); color: #34C759; }

/* ========== Footer ========== */
.footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 40rpx 56rpx;
}

.update-time {
  font-size: 22rpx;
  color: #8E8E93;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.update-dot {
  width: 10rpx;
  height: 10rpx;
  background-color: #34C759;
  border-radius: 50%;
}

.btn-refresh {
  background: #000000;
  color: #FFFFFF;
  padding: 16rpx 32rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 700;
}
