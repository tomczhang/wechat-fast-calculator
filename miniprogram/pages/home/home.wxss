.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #F4F5F7;
}

/* ========== Header ========== */
.header {
  padding: 28rpx 40rpx 20rpx;
  background: #FFFFFF;
}

.header-title {
  display: block;
  font-size: 36rpx;
  font-weight: 900;
  letter-spacing: -0.02em;
  line-height: 1.3;
}

/* ========== Loading ========== */
.loading-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 40rpx;
  background: #FFFFFF;
}

.spinner-sm {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid #E5E5EA;
  border-top-color: #000;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text { font-size: 24rpx; color: #8E8E93; font-weight: 500; }

/* ========== Error ========== */
.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.error-text { color: #FF3B30; font-size: 28rpx; margin-bottom: 32rpx; }

/* ========== Section ========== */
.section { padding: 24rpx 28rpx 0; }

.section-label {
  font-size: 24rpx;
  color: #8E8E93;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

/* ========== 宽指卡片 ========== */
.index-cards { display: flex; flex-direction: column; gap: 16rpx; }

.index-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.06);
}

.index-card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.index-card-left { display: flex; align-items: baseline; gap: 12rpx; }

.index-ticker { font-size: 36rpx; font-weight: 900; letter-spacing: -0.03em; }

.index-name { font-size: 24rpx; color: #8E8E93; font-weight: 500; }

.index-drop {
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 900;
  letter-spacing: -0.02em;
}

.index-card-meta {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.meta-row { display: flex; flex-direction: column; gap: 2rpx; }

.meta-label { font-size: 20rpx; color: #AEAEB2; font-weight: 500; }

.meta-value { font-size: 26rpx; font-weight: 700; color: #333; }

.index-card-bottom { margin-top: 16rpx; }

/* ========== 击球点 ========== */
.strike-badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.strike-active {
  background: rgba(255, 59, 48, 0.1);
  color: #FF3B30;
}

.strike-inactive {
  background: rgba(142, 142, 147, 0.06);
  color: #AEAEB2;
  font-weight: 500;
}

.strike-tag {
  display: inline-flex;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  background: #FF3B30;
  color: #FFF;
  font-size: 18rpx;
  font-weight: 700;
  margin-left: 8rpx;
}

/* ========== VIX 卡片 ========== */
.vix-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

/* ========== ECG 心跳动画 ========== */
.ecg-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5rpx;
  height: 80rpx;
  margin-bottom: 16rpx;
}

.ecg-bar {
  flex-shrink: 0;
  width: 8rpx;
  border-radius: 4rpx;
  background: currentColor;
  animation: ecg-beat 1.5s ease-in-out infinite;
}

.ecg-slow .ecg-bar { animation-duration: 2s; }
.ecg-medium .ecg-bar { animation-duration: 1.4s; }
.ecg-fast .ecg-bar { animation-duration: 0.9s; }
.ecg-fastest .ecg-bar { animation-duration: 0.5s; }

.panic-normal .ecg-bar { color: #34C759; }
.panic-elevated .ecg-bar { color: #FF9500; }
.panic-high .ecg-bar { color: #FF3B30; }
.panic-extreme .ecg-bar { color: #AF0000; }

@keyframes ecg-beat {
  0%, 100% { transform: scaleY(0.15); opacity: 0.3; }
  50% { transform: scaleY(1); opacity: 1; }
}

.vix-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.vix-left { display: flex; align-items: baseline; gap: 12rpx; }

.vix-value { font-size: 44rpx; font-weight: 900; letter-spacing: -0.03em; }

.vix-change { font-size: 24rpx; font-weight: 600; }

.vix-up { color: #FF3B30; }
.vix-down { color: #34C759; }

.panic-tag {
  padding: 10rpx 24rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.panic-tag.panic-normal { background: rgba(52, 199, 89, 0.1); color: #34C759; }
.panic-tag.panic-elevated { background: rgba(255, 149, 0, 0.1); color: #FF9500; }
.panic-tag.panic-high { background: rgba(255, 59, 48, 0.1); color: #FF3B30; }
.panic-tag.panic-extreme { background: rgba(175, 0, 0, 0.15); color: #AF0000; }

/* ========== 个股列表 ========== */
.stock-list { display: flex; flex-direction: column; gap: 12rpx; }

.stock-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.stock-left { display: flex; align-items: center; gap: 16rpx; flex: 1; min-width: 0; }

.stock-rank {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  background: #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
  color: #8E8E93;
  flex-shrink: 0;
}

.rank-strike { background: rgba(255, 59, 48, 0.1); color: #FF3B30; }

.stock-info { flex: 1; min-width: 0; }

.stock-top-row { display: flex; align-items: center; }

.stock-ticker { font-size: 28rpx; font-weight: 800; letter-spacing: -0.02em; }

.stock-name { font-size: 22rpx; color: #8E8E93; font-weight: 500; margin-left: 8rpx; }

.stock-meta-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 4rpx;
}

.stock-meta { font-size: 20rpx; color: #AEAEB2; font-weight: 500; }

.stock-meta-sep { font-size: 18rpx; color: #D1D1D6; }

.stock-badge {
  padding: 8rpx 16rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: -0.02em;
  min-width: 110rpx;
  text-align: center;
  flex-shrink: 0;
}

.dd-red { background: rgba(255, 51, 51, 0.08); color: #FF3333; }
.dd-orange { background: rgba(255, 149, 0, 0.08); color: #FF9500; }
.dd-green { background: rgba(52, 199, 89, 0.08); color: #34C759; }

/* ========== Footer ========== */
.footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 40rpx 56rpx;
}

.update-time {
  font-size: 22rpx;
  color: #8E8E93;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.update-dot {
  width: 10rpx;
  height: 10rpx;
  background-color: #34C759;
  border-radius: 50%;
}

.btn-refresh {
  background: #000000;
  color: #FFFFFF;
  padding: 16rpx 32rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 700;
}
