.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #FFFFFF;
}

/* ========== Header ========== */

.header {
  padding: 24rpx 48rpx 16rpx;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 900;
  letter-spacing: -0.04em;
  line-height: 1.1;
}

.header-sub {
  display: block;
  font-size: 22rpx;
  color: #8E8E93;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-weight: 500;
  margin-top: 6rpx;
}

/* ========== Loading ========== */

.loading-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 48rpx;
  background: #F9F9FB;
}

.spinner-sm {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid #E5E5EA;
  border-top-color: #000;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: #8E8E93;
  font-weight: 500;
}

/* ========== Error ========== */

.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.error-text {
  color: #FF3B30;
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

/* ========== List ========== */

.list-section {
  flex-grow: 1;
  background: #F4F5F7;
  border-radius: 48rpx 48rpx 0 0;
  padding: 28rpx 28rpx 0;
  box-shadow: 0 -10rpx 40rpx rgba(0,0,0,0.03);
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(0,0,0,0.04);
}

.item-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.item-rank {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
  color: #8E8E93;
}

.item-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.item-ticker {
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: -0.02em;
}

.item-name {
  font-size: 22rpx;
  color: #8E8E93;
  font-weight: 500;
}

.item-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.item-price {
  font-size: 24rpx;
  color: #8E8E93;
  font-weight: 500;
}

.item-badge {
  padding: 8rpx 16rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  font-weight: 800;
  letter-spacing: -0.02em;
  min-width: 120rpx;
  text-align: center;
}

.dd-red { background: rgba(255, 51, 51, 0.08); color: #FF3333; }
.dd-orange { background: rgba(255, 149, 0, 0.08); color: #FF9500; }
.dd-green { background: rgba(52, 199, 89, 0.08); color: #34C759; }

/* ========== Footer ========== */

.footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 40rpx 56rpx;
  background: #F4F5F7;
}

.update-time {
  font-size: 22rpx;
  color: #8E8E93;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.update-dot {
  width: 10rpx;
  height: 10rpx;
  background-color: #34C759;
  border-radius: 50%;
}

.btn-refresh {
  background: #000000;
  color: #FFFFFF;
  padding: 16rpx 32rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 700;
}
