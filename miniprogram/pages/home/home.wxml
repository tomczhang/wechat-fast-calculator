<view class="container">
  <view class="header">
    <text class="header-title">核心标的距近6个月前高总览</text>
  </view>

  <view class="loading-bar" wx:if="{{loading}}">
    <view class="spinner-sm"></view>
    <text class="loading-text">获取数据...</text>
  </view>

  <view class="error-wrap" wx:if="{{error && !indexes.length}}">
    <text class="error-text">{{error}}</text>
    <view class="btn-refresh" bindtap="onRefresh">重试</view>
  </view>

  <block wx:if="{{indexes.length}}">
    <!-- 宽指区域 -->
    <view class="section">
      <view class="section-label">宽指 ETF</view>
      <view class="index-cards">
        <view class="index-card" wx:for="{{indexes}}" wx:key="ticker" data-type="index" bindtap="onItemTap">
          <view class="index-card-top">
            <view class="index-card-left">
              <text class="index-ticker">{{item.ticker}}</text>
              <text class="index-name">{{item.nameCN}}</text>
            </view>
            <view class="index-drop {{item.dropClass}}">
              <text>{{item.dropFromHigh}}%</text>
            </view>
          </view>
          <view class="index-card-meta">
            <view class="meta-row">
              <text class="meta-label">现价</text>
              <text class="meta-value">${{item.currentPrice}}</text>
            </view>
            <view class="meta-row">
              <text class="meta-label">前高</text>
              <text class="meta-value">${{item.highPrice}}</text>
            </view>
            <view class="meta-row">
              <text class="meta-label">前高日期</text>
              <text class="meta-value">{{item.highDate}}</text>
            </view>
          </view>
          <view class="index-card-bottom">
            <view class="strike-badge strike-active" wx:if="{{item.strikeZone}}">
              <text>击球点已触发 ({{item.threshold}}%)</text>
            </view>
            <view class="strike-badge strike-inactive" wx:else>
              <text>击球点 {{item.threshold}}% 未触发</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- VIX 区域 -->
    <view class="section" wx:if="{{vix}}">
      <view class="section-label">VIX 恐慌指数</view>
      <view class="vix-card {{vix.panicClass}}">
        <view class="ecg-wrap {{vix.ecgSpeed}}">
          <view class="ecg-bar" wx:for="{{vix.ecgBars}}" wx:key="index"
            style="height: {{item.h}}rpx; animation-delay: {{item.d}}ms">
          </view>
        </view>
        <view class="vix-info">
          <view class="vix-left">
            <text class="vix-value">{{vix.value}}</text>
            <text class="vix-change {{vix.changeClass}}">{{vix.changeSign}}{{vix.change}} ({{vix.changeSign}}{{vix.changePercent}}%)</text>
          </view>
          <view class="panic-tag {{vix.panicClass}}">
            <text>{{vix.panicLabel}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 个股区域 -->
    <view class="section">
      <view class="section-label">七姐妹 + 台积电</view>
      <view class="stock-list">
        <view class="stock-item" wx:for="{{stocks}}" wx:key="ticker" data-type="stock" bindtap="onItemTap">
          <view class="stock-left">
            <view class="stock-rank {{item.strikeZone ? 'rank-strike' : ''}}">{{index + 1}}</view>
            <view class="stock-info">
              <view class="stock-top-row">
                <text class="stock-ticker">{{item.ticker}}</text>
                <text class="stock-name">{{item.nameCN}}</text>
                <view class="strike-tag" wx:if="{{item.strikeZone}}">
                  <text>击球点</text>
                </view>
              </view>
              <view class="stock-meta-row">
                <text class="stock-meta">现价 ${{item.currentPrice}}</text>
                <text class="stock-meta-sep">|</text>
                <text class="stock-meta">前高 ${{item.highPrice}} ({{item.highDate}})</text>
              </view>
            </view>
          </view>
          <view class="stock-badge {{item.dropClass}}">
            <text>{{item.dropFromHigh}}%</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部 -->
    <view class="footer">
      <view class="update-time" wx:if="{{updateTime}}">
        <view class="update-dot"></view>
        <text>{{updateTime}} 更新</text>
      </view>
      <view class="btn-refresh" bindtap="onRefresh">
        <text wx:if="{{loading}}">刷新中...</text>
        <text wx:else>刷新</text>
      </view>
    </view>
  </block>
</view>
